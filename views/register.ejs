<%- include('partials/head') %> 

<main
  class="container mx-auto px-6 py-16 flex justify-center items-center flex-grow"
>
  <div
    class="max-w-md w-full bg-white p-10 rounded-3xl shadow-2xl border border-gray-100"
  >
    <div class="text-center mb-10">
      <h2 class="text-4xl font-black italic tracking-tighter uppercase italic">
        Únete al Crew
      </h2>
      <p class="text-gray-500 text-sm mt-2 font-medium">
        Crea tu cuenta en StyleHub y recibe drops exclusivos.
      </p>
    </div>

    <form action="/register" method="POST" class="space-y-6">
      <div>
        <label
          class="block text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2 italic"
          >Nombre Completo</label
        >
        <input
          type="text"
          name="fullName"
          placeholder="Tu nombre"
          required
          class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-black focus:border-black transition outline-none"
        />
      </div>

      <div>
        <label
          class="block text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2 italic"
          >Correo Electrónico</label
        >
        <input
          type="email"
          name="email"
          placeholder="ejemplo@correo.com"
          required
          class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-black focus:border-black transition outline-none"
        />
      </div>

      <div>
        <label
          class="block text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2 italic"
          >Contraseña</label
        >
        <input
          type="password"
          name="password"
          placeholder="Mínimo 8 caracteres"
          required
          class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-black focus:border-black transition outline-none"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-black text-white py-4 rounded-xl font-black uppercase tracking-widest hover:bg-gray-800 transition shadow-xl transform active:scale-95"
      >
        Registrarse
      </button>
    </form>

    <div class="mt-8 text-center pt-6 border-t border-gray-50">
      <p class="text-gray-500 text-sm">
        ¿Ya eres parte del crew?
        <a href="/login" class="text-black font-bold hover:underline"
          >Inicia sesión</a
        >
      </p>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
