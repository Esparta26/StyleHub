<%- include('./partials/head') %>
<%- include('./partials/header') %>

<main class="container mx-auto px-6 py-16 flex justify-center items-center flex-grow">
  <div class="max-w-md w-full bg-white p-10 rounded-3xl shadow-2xl border border-gray-100 text-center">
    
    <div class="w-24 h-24 mx-auto bg-black text-white rounded-full flex items-center justify-center text-4xl font-black italic mb-6 shadow-lg">
      <%= locals.userLogged && locals.userLogged.fullName ? locals.userLogged.fullName.charAt(0).toUpperCase() : 'S' %>
    </div>
    
    <h2 class="text-3xl font-black italic tracking-tighter uppercase mb-1">
      <%= locals.userLogged && locals.userLogged.fullName ? locals.userLogged.fullName : 'Miembro del Crew' %>
    </h2>
    <p class="text-gray-500 font-medium mb-8 tracking-wide">
      <%= locals.userLogged ? locals.userLogged.email : 'correo@stylehub.com' %>
    </p>
    
    <div class="space-y-4 pt-4 border-t border-gray-100">
      <a href="/home" class="block w-full bg-black text-white py-4 rounded-xl font-black uppercase tracking-widest hover:bg-gray-800 transition shadow-xl transform active:scale-95">
        Ir al Catálogo
      </a>
      <a href="/logout" class="block w-full bg-red-50 text-red-600 py-4 rounded-xl font-bold uppercase tracking-widest hover:bg-red-100 transition">
        Cerrar Sesión
      </a>
    </div>

  </div>
</main>

<%- include('./partials/footer') %>